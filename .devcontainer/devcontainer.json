{
    "name": "BET Pipeline Dev Environment",
    "dockerComposeFile": [
        "../docker-compose.yml",
        "docker-compose.dev.yml"
    ],
    "service": "app",
    "runServices": [
        "app",
        "db",
        "pgadmin"
    ],
    "workspaceFolder": "/app",
    "shutdownAction": "stopCompose",
    "forwardPorts": [
        5432,
        5050
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "usernamehw.errorlens",
                "charliermarsh.ruff",
                "tamasfe.even-better-toml",
                "mhutchie.git-graph",
                "github.copilot-chat",
                "mtxr.sqltools",
                "mtxr.sqltools-driver-pg"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.envFile": "${workspaceFolder}/.env"
            }
        }
    },
    // Run the container as root to avoid permission issues editing mounted files
    "remoteUser": "root",
    "updateContentCommand": "apt-get update && apt-get install -y bubblewrap socat",
    "postCreateCommand": "pip install --no-cache-dir -r requirements.txt && pip install --no-cache-dir pytest debugpy ruff",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {}
    }
}