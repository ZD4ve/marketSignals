{
    "name": "BET Pipeline Dev Environment",
    "dockerComposeFile": [
        "../docker-compose.yml",
        "docker-compose.dev.yml"
    ],
    "service": "app",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "usernamehw.errorlens",
                "charliermarsh.ruff",
                "tamasfe.even-better-toml",
                "mhutchie.git-graph",
                "github.copilot-chat",
                "mtxr.sqltools",
                "mtxr.sqltools-driver-pg"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    },
    // Run the container as root to avoid permission issues editing mounted files
    "remoteUser": "root",
    "postCreateCommand": "pip install pytest debugpy ruff",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {}
    }
}